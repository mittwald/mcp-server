# Authentication Mode
# Set to 'true' to disable OAuth and run without authentication
# Useful for API key based services or development
DISABLE_OAUTH=false

# Reddit OAuth Application Credentials (required if DISABLE_OAUTH=false)
# These are YOUR app's credentials from Reddit, NOT user tokens
# Create a Reddit app at: https://www.reddit.com/prefs/apps
# App type should be "web app" with redirect URI matching REDIRECT_URL below
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here

# JWT Secret for MCP token signing (required if DISABLE_OAUTH=false)
# The MCP server creates its own JWT tokens that contain Reddit OAuth tokens
# Generate a secure random string (e.g., openssl rand -base64 32)
JWT_SECRET=your-super-secure-jwt-secret-key-here-make-it-long-and-random

# Mittwald API Credentials (example for API key based services)
# MITTWALD_API_TOKEN=your_mittwald_api_token_here
# MITTWALD_SSH_PASSWORD=your_ssh_password_here
# MITTWALD_ADMIN_EMAIL=your_email@example.com

# Test Configuration (required for running tests)
# TEST_SERVER_ID=your_mittwald_server_id_here
# TEST_ADMIN_EMAIL=test@example.com
# SKIP_TEST_CLEANUP=false  # Set to true to keep test projects for debugging
# TEST_PARALLEL=true       # Set to false to run tests sequentially

# Server Configuration
PORT=3000

# OAuth Configuration  
# The following are automatically constructed from PORT
# Only set these if you need to override the defaults
# OAUTH_ISSUER=http://localhost:3000
# REDIRECT_URL=http://localhost:3000/oauth/reddit/callback

# Reddit API Identity Configuration
# IMPORTANT: These identify your APPLICATION to Reddit, not the end users
# Reddit requires a specific User-Agent format for all API requests
# Format: <platform>:<app_id>:<version> (by /u/<developer_reddit_username>)
# Example: linux:my-reddit-app:v1.0.0 (by /u/my_developer_account)
# Note: The username should be YOUR (the developer's) Reddit account, not end users
REDDIT_USER_AGENT=YourApp:v1.0.0 (by /u/YourRedditUsername)

# Your Reddit developer account username (without /u/ prefix)
# This is used to construct the User-Agent string for API compliance
# It should be the Reddit account that registered the OAuth app
REDDIT_USERNAME=your-reddit-username

# Optional - Logging
# LOG_LEVEL=info
# DEBUG=false

# Tool Filtering Configuration (optional)
# Enable tool filtering to limit the number of tools returned in the MCP response
# This can help prevent overwhelming clients when there are many tools (170+)
TOOL_FILTER_ENABLED=false

# Maximum number of tools to return per response (default: 50)
# Only applies when TOOL_FILTER_ENABLED=true
MAX_TOOLS_PER_RESPONSE=50

# Comma-separated list of allowed tool categories
# Available categories: app, project, database, cronjob, backup, domain, mail, org, container, 
# context, conversation, ddev, extension, server, ssh, sftp, user, contributor
# Leave empty to include all categories
# ALLOWED_TOOL_CATEGORIES=app,project,database

# Example configurations:
# 1. Return only app management tools (limit 30):
#    TOOL_FILTER_ENABLED=true
#    MAX_TOOLS_PER_RESPONSE=30
#    ALLOWED_TOOL_CATEGORIES=app
#
# 2. Return core tools only (project, app, database):
#    TOOL_FILTER_ENABLED=true
#    MAX_TOOLS_PER_RESPONSE=50
#    ALLOWED_TOOL_CATEGORIES=project,app,database
#
# 3. Disable filtering (return all 170+ tools) - default:
#    TOOL_FILTER_ENABLED=false