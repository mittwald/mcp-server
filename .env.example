# HTTPS Configuration
ENABLE_HTTPS=true
SSL_KEY_PATH=/app/ssl/server.key
SSL_CERT_PATH=/app/ssl/server.crt

# OAuth 2.0 Configuration
OAUTH_ISSUER=http://localhost:8080/default
OAUTH_REDIRECT_URI=https://localhost:3000/auth/callback
MITTWALD_OAUTH_CLIENT_ID=mittwald-mcp-server
MITTWALD_OAUTH_CLIENT_SECRET=mock-client-secret

# Optional: override scope configuration path (defaults to ./config/mittwald-scopes.json)
# MITTWALD_SCOPE_CONFIG_PATH=/app/config/mittwald-scopes.json

# Test Configuration (required for running tests)
# TEST_SERVER_ID=your_mittwald_server_id_here
# TEST_ADMIN_EMAIL=test@example.com
# SKIP_TEST_CLEANUP=false  # Set to true to keep test projects for debugging
# TEST_PARALLEL=true       # Set to false to run tests sequentially

# Server Configuration
PORT=3000

# Redis Configuration
REDIS_URL=redis://localhost:6379

# OAuth 2.0 Configuration (for multitenant deployment)
# Production Mittwald Studio URLs:
# MITTWALD_OAUTH_CLIENT_ID=your_client_id
# MITTWALD_OAUTH_CLIENT_SECRET=your_client_secret
# OAUTH_AUTHORIZATION_URL=https://studio.mittwald.de/oauth2/authorize
# OAUTH_TOKEN_URL=https://studio.mittwald.de/oauth2/token
# OAUTH_REDIRECT_URI=https://your-mcp-server.com/auth/callback

# Development/Testing with MockOAuth2Server:
MITTWALD_OAUTH_CLIENT_ID=mittwald-mcp-server
MITTWALD_OAUTH_CLIENT_SECRET=mock-client-secret
OAUTH_AUTHORIZATION_URL=http://localhost:8080/default/authorize
OAUTH_TOKEN_URL=http://localhost:8080/default/token
OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback
OAUTH_ISSUER=http://localhost:8080/default

# Session Configuration
# SESSION_SECRET=your_session_secret
# SESSION_TTL=28800  # 8 hours in seconds

# JWT Configuration (required for OAuth)
JWT_SECRET=your_jwt_secret_key_here

# Optional - Logging
# LOG_LEVEL=info
# DEBUG=false

# OAuth State Management
# STATE_TTL=600  # OAuth state expiration in seconds (default: 10 minutes)

# Development/Docker specific overrides
# For Docker Compose, these may be overridden in docker-compose.yml:
# OAUTH_ISSUER=http://mock-oauth:8080/default  # Docker service name
# REDIS_URL=redis://redis:6379  # Docker service name

# Tool Filtering Configuration (optional)
# Enable tool filtering to limit the number of tools returned in the MCP response
# This can help prevent overwhelming clients when there are many tools (170+)
TOOL_FILTER_ENABLED=false

# Maximum number of tools to return per response (default: 50)
# Only applies when TOOL_FILTER_ENABLED=true
MAX_TOOLS_PER_RESPONSE=50

# Comma-separated list of allowed tool categories
# Available categories: app, project, database, cronjob, backup, domain, mail, org, container, 
# context, conversation, ddev, extension, server, ssh, sftp, user, contributor
# Leave empty to include all categories
# ALLOWED_TOOL_CATEGORIES=app,project,database

# Example configurations:
# 1. Return only app management tools (limit 30):
#    TOOL_FILTER_ENABLED=true
#    MAX_TOOLS_PER_RESPONSE=30
#    ALLOWED_TOOL_CATEGORIES=app
#
# 2. Return core tools only (project, app, database):
#    TOOL_FILTER_ENABLED=true
#    MAX_TOOLS_PER_RESPONSE=50
#    ALLOWED_TOOL_CATEGORIES=project,app,database
#
# 3. Disable filtering (return all 170+ tools) - default:
#    TOOL_FILTER_ENABLED=false
