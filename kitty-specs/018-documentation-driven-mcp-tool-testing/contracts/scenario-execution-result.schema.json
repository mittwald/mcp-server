{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mittwald-mcp.dev/schemas/scenario-execution-result.json",
  "title": "ScenarioExecutionResult",
  "description": "Records the outcome of running a scenario",
  "type": "object",
  "required": [
    "scenario_id",
    "run_id",
    "executed_at",
    "status",
    "tools_called",
    "execution_time_ms",
    "resources_created",
    "cleanup_performed"
  ],
  "properties": {
    "scenario_id": {
      "type": "string",
      "description": "Identifier of the scenario that was executed"
    },
    "run_id": {
      "type": "string",
      "pattern": "^run-[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}-[0-9]{2}-[0-9]{2}$",
      "description": "Timestamp-based run identifier",
      "examples": ["run-2026-01-27T14-23-45"]
    },
    "executed_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of execution start"
    },
    "status": {
      "type": "string",
      "enum": ["success", "failure"],
      "description": "Overall outcome of the scenario execution"
    },
    "tools_called": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^mittwald_[a-z_]+$"
      },
      "description": "MCP tool names called during execution, in order"
    },
    "execution_time_ms": {
      "type": "number",
      "minimum": 0,
      "description": "Total execution time in milliseconds"
    },
    "failure_details": {
      "type": "object",
      "description": "Details if status is 'failure'",
      "required": ["failed_tool", "error_message", "context"],
      "properties": {
        "failed_tool": {
          "type": "string",
          "description": "Tool that caused the failure"
        },
        "error_message": {
          "type": "string",
          "description": "Error message from the failure"
        },
        "error_code": {
          "type": "string",
          "description": "Error code if available"
        },
        "context": {
          "type": "object",
          "additionalProperties": true,
          "description": "Additional context about the failure"
        }
      }
    },
    "resources_created": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "id"],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "project",
              "app",
              "database",
              "backup_schedule",
              "domain",
              "container",
              "user"
            ],
            "description": "Type of resource created"
          },
          "id": {
            "type": "string",
            "description": "Resource identifier (e.g., p-abc123, app-xyz789)"
          },
          "name": {
            "type": "string",
            "description": "Human-readable resource name"
          }
        }
      },
      "description": "Resources created during scenario execution"
    },
    "cleanup_performed": {
      "type": "boolean",
      "description": "Whether cleanup was attempted"
    },
    "cleanup_errors": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Errors encountered during cleanup"
    },
    "log_file_path": {
      "type": "string",
      "description": "Path to full execution log file"
    }
  }
}
