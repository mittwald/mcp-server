{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://mittwald-mcp.dev/schemas/scenario-definition.json",
  "title": "ScenarioDefinition",
  "description": "Defines a test scenario that exercises MCP tools through natural language prompts",
  "type": "object",
  "required": ["id", "name", "prompts", "success_criteria"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Unique scenario identifier in kebab-case",
      "examples": ["freelancer-onboarding", "backup-monitoring"]
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable scenario name",
      "examples": ["Freelancer Client Onboarding", "Automated Backup Monitoring"]
    },
    "source": {
      "type": "string",
      "description": "Path to case study documentation (if applicable)",
      "examples": ["docs/setup-and-guides/src/content/docs/case-studies/freelancer-client-onboarding.md"]
    },
    "prompts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "description": "Prompts to send to Claude Code CLI in sequence",
      "examples": [
        ["Create a new Mittwald project called 'ACME Client Portal'", "Install WordPress in that project"]
      ]
    },
    "success_criteria": {
      "type": "object",
      "description": "Outcome-based validation criteria",
      "properties": {
        "resources_created": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          },
          "description": "Expected resource counts (e.g., project: 1, app: 2)",
          "examples": [
            { "project": 1, "app": 1, "backup_schedule": 1 }
          ]
        },
        "resources_configured": {
          "type": "object",
          "additionalProperties": true,
          "description": "Expected configuration states",
          "examples": [
            { "ssl_enabled": true, "backup_frequency": "daily" }
          ]
        }
      },
      "anyOf": [
        { "required": ["resources_created"] },
        { "required": ["resources_configured"] }
      ]
    },
    "cleanup": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Cleanup prompts for resource teardown",
      "examples": [
        ["Delete the WordPress app", "Delete the project"]
      ]
    },
    "expected_tools": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^mittwald_[a-z_]+$"
      },
      "description": "Optional: MCP tools expected to be called",
      "examples": [
        ["mittwald_project_create", "mittwald_app_install"]
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Categorization tags",
      "examples": [
        ["case-study", "simple", "tier-3"]
      ]
    },
    "fixtures": {
      "type": "object",
      "description": "Resources to provision before scenario execution (supports template variables)",
      "properties": {
        "project": {
          "type": "object",
          "properties": {
            "description": {
              "type": "string",
              "description": "Project description (supports {{RUN_ID}} template)"
            },
            "serverId": {
              "type": "string",
              "description": "Server ID (optional, falls back to DEFAULT_SERVER_ID env var)"
            }
          },
          "required": ["description"]
        },
        "databases": {
          "type": "object",
          "properties": {
            "mysql": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "description": { "type": "string" },
                  "version": { "type": "string" },
                  "characterSet": { "type": "string" },
                  "collation": { "type": "string" }
                },
                "required": ["description", "version"]
              }
            },
            "redis": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "description": { "type": "string" },
                  "version": { "type": "string" },
                  "maxMemory": { "type": "string" },
                  "maxMemoryPolicy": { "type": "string" }
                },
                "required": ["description", "version"]
              }
            }
          }
        },
        "apps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "appName": { "type": "string" },
              "appVersion": { "type": "string" }
            },
            "required": ["description", "appName", "appVersion"]
          }
        },
        "domains": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "fqdn": {
                "type": "string",
                "description": "Fully qualified domain name (supports {{RUN_ID}} template)"
              },
              "virtualhost": {
                "type": "boolean",
                "description": "Create virtualhost for this domain"
              }
            },
            "required": ["fqdn"]
          }
        },
        "mail": {
          "type": "object",
          "properties": {
            "addresses": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "address": { "type": "string" },
                  "password": { "type": "string" },
                  "quota": { "type": "string" }
                },
                "required": ["address"]
              }
            },
            "deliveryboxes": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "description": { "type": "string" },
                  "password": { "type": "string" }
                },
                "required": ["description"]
              }
            }
          }
        },
        "ssh_users": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "publicKey": { "type": "string" }
            },
            "required": ["description"]
          }
        },
        "backups": {
          "type": "object",
          "properties": {
            "schedules": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "description": { "type": "string" },
                  "schedule": { "type": "string" },
                  "ttl": { "type": "string" }
                },
                "required": ["description", "schedule", "ttl"]
              }
            }
          }
        },
        "containers": {
          "type": "object",
          "properties": {
            "stacks": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "description": { "type": "string" },
                  "composeFile": { "type": "string" }
                },
                "required": ["description"]
              }
            },
            "registries": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "description": { "type": "string" },
                  "uri": { "type": "string" },
                  "username": { "type": "string" },
                  "password": { "type": "string" }
                },
                "required": ["description", "uri"]
              }
            }
          }
        }
      }
    }
  }
}
