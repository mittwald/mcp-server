{
  "name": "@systemprompt/systemprompt-mcp-server",
  "version": "1.0.1",
  "description": "Mittwald MCP server implementation providing tools for managing hosting infrastructure through the Model Context Protocol. Supports apps, projects, databases, containers, and domains via Mittwald API.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    }
  },
  "bin": {
    "systemprompt-mcp-server": "build/index.js"
  },
  "files": [
    "build",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "workspaces": [
    "packages/*"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc && tsc-alias && chmod +x build/index.js && echo \"export * from './config.js';\nexport * from './oauth.js';\nexport * from './mcp.js';\nexport * from './auth-store.js';\nexport * from './types.js';\" > build/server/index.js",
    "build:workspaces": "npm run build --workspace=packages/mittwald-cli-core --if-present && npm run build --workspace=packages/oauth-bridge --if-present",
    "build:all": "npm run build:workspaces && npm run build",
    "types:generate": "npx json-schema-to-typescript kitty-specs/018-documentation-driven-mcp-tool-testing/contracts/scenario-definition.schema.json > src/types/scenario.ts && npx json-schema-to-typescript kitty-specs/018-documentation-driven-mcp-tool-testing/contracts/scenario-execution-result.schema.json > src/types/scenario-execution.ts",
    "watch": "tsc --watch",
    "lint": "eslint .",
    "lint:credential-leak": "eslint src/handlers packages/oauth-bridge/src --config ./eslint.credential.config.js",
    "type-check": "tsc --noEmit",
    "docker": "docker-compose build && docker-compose up -d",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:bridge": "vitest run --root packages/oauth-bridge --config ./vitest.config.ts",
    "test:session": "vitest run tests/integration",
    "test:smoke": "vitest run tests/smoke",
    "test:security": "vitest run tests/security",
    "test:functional": "vitest run tests/functional --reporter=verbose --no-file-parallelism",
    "test:functional:watch": "vitest tests/functional --reporter=verbose --no-file-parallelism",
    "test:cleanup": "vitest run tests/functional/full-lifecycle.test.ts -t 'Manual Cleanup'",
    "test:phases": "tsx tests/run-phase-tests.ts",
    "test:validation": "tsx tests/validation/run-validation.ts",
    "test:wp04": "tsx tests/validation/validate-wp04-pilot.ts",
    "test:phase:setup": "TEST_PHASE=setup npm run test:functional",
    "test:phase:test": "TEST_PHASE=test npm run test:functional",
    "test:phase:teardown": "TEST_PHASE=teardown npm run test:functional",
    "test:single": "vitest run --reporter=verbose --no-file-parallelism",
    "test:oauth": "vitest run tests/unit/auth tests/integration/oauth-flow.test.ts --reporter=verbose",
    "test:oauth:watch": "vitest tests/unit/auth tests/integration/oauth-flow.test.ts --reporter=verbose",
    "test:oauth:mock": "vitest run tests/integration/mock-oauth2-server.test.ts --reporter=verbose",
    "test:e2e": "vitest run tests/e2e",
    "test:e2e:mcp": "tsx scripts/e2e-mcp-oauth.ts",
    "test:oauth:coverage": "vitest run tests/unit/auth tests/integration --coverage --reporter=verbose",
    "test:all": "npm run test:unit && npm run test:bridge && npm run test:session && npm run test:integration && npm run test:e2e",
    "inspector": "npx @modelcontextprotocol/inspector",
    "logs:registration": "bash scripts/tail-registration-logs.sh",
    "coverage:generate": "tsx scripts/generate-mw-coverage.ts",
    "check:cli-version": "tsx scripts/check-cli-version.ts",
    "docs:guardrails": "tsx scripts/docs-guardrails.ts",
    "generate:context-flags": "tsx scripts/generate-context-flag-map.ts",
    "eval:quick-start": "bash evals/scripts/quick-start.sh",
    "eval:run:create": "tsx evals/scripts/run-manager.ts create",
    "eval:run:list": "tsx evals/scripts/run-manager.ts list",
    "eval:run:set-active": "tsx evals/scripts/run-manager.ts set-active",
    "eval:run:get-active": "tsx evals/scripts/run-manager.ts get-active",
    "eval:run:compare": "tsx evals/scripts/run-manager.ts compare",
    "eval:report": "tsx evals/scripts/generate-multi-run-report.ts",
    "eval:compare:visual": "tsx evals/scripts/visual-comparison.ts",
    "eval:save-result": "tsx evals/scripts/save-eval-result.ts",
    "eval:migrate": "tsx evals/scripts/migrate-to-run.ts",
    "eval:best-of": "tsx evals/scripts/aggregate-best-of.ts",
    "eval:agent:e2e": "tsx evals/scripts/agent-e2e-runner.ts",
    "eval:agent:auth": "tsx evals/scripts/agent-auth-bootstrap.ts",
    "eval:agent:preflight": "tsx evals/scripts/agent-e2e-runner.ts --preflight-only --require-coverage=0",
    "eval:agent:report": "tsx evals/scripts/agent-e2e-report.ts",
    "scenarios:validate": "tsx evals/scripts/validate-scenarios.ts",
    "scenarios:validate-all": "tsx evals/scripts/validate-all-scenarios.ts",
    "scenarios:auto-approve": "tsx scripts/auto-approve-mcp-tools.ts",
    "scenario:run": "tsx evals/scripts/scenario-runner.ts",
    "scenario:run-direct": "tsx evals/scripts/direct-scenario-runner.ts",
    "scenarios:retry-failures": "tsx evals/scripts/retry-failures.ts",
    "coverage:query": "tsx evals/scripts/coverage-query.ts",
    "failures:cluster": "tsx evals/scripts/cluster-failures.ts",
    "failures:report": "tsx evals/scripts/generate-failure-report.ts",
    "report:coverage-json": "tsx evals/scripts/generate-coverage-report.ts",
    "report:coverage-md": "tsx evals/scripts/generate-markdown-report.ts",
    "report:coverage": "npm run report:coverage-json && npm run report:coverage-md",
    "analysis:gaps": "tsx evals/scripts/gap-analysis.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/systempromptio/systemprompt-mcp-server.git"
  },
  "dependencies": {
    "@mittwald/api-client": "^4.169.0",
    "@modelcontextprotocol/sdk": "^1.13.0",
    "@types/jsonwebtoken": "^9.0.10",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "fast-redact": "^3.5.0",
    "ioredis": "^5.7.0",
    "jose": "^6.0.11",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "openid-client": "^6.6.2",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "semver": "^7.6.3",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@mittwald/cli": "^1.12.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/js-yaml": "^4.0.9",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^22.15.33",
    "@types/pino": "^7.0.4",
    "@types/semver": "^7.7.1",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "@typescript-eslint/parser": "^8.34.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "axios": "^1.12.2",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.5.0",
    "jsdom": "^27.0.0",
    "json-schema-to-typescript": "^15.0.4",
    "playwright": "^1.58.0",
    "prettier": "^3.5.3",
    "supertest": "^7.1.4",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^7.1.9",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "mittwald",
    "mcp",
    "model-context-protocol",
    "mcp-server",
    "hosting",
    "infrastructure",
    "typescript",
    "type-safe",
    "api-client",
    "domains",
    "containers",
    "projects"
  ],
  "author": "SystemPrompt",
  "bugs": {
    "url": "https://github.com/systempromptio/systemprompt-mcp-server/issues"
  },
  "homepage": "https://systemprompt.io",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24.11.0"
  }
}
