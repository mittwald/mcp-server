# Test environment configuration for OAuth tests
NODE_ENV=test
DEBUG=false

# Redis Configuration
REDIS_URL=redis://localhost:6379

# OAuth Configuration for Testing
DISABLE_OAUTH=false
OAUTH_ISSUER=http://localhost:8080/default
OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback
JWT_SECRET=test-jwt-secret-for-oauth-integration-tests

# MockOAuth2Server Client Configuration
MITTWALD_OAUTH_CLIENT_ID=mittwald-mcp-server
MITTWALD_OAUTH_CLIENT_SECRET=test-client-secret

# Test Server Configuration
PORT=3000
ENABLE_HTTPS=false

# Session Configuration
SESSION_TTL=3600