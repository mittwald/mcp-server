# OAuth Server Configuration
ISSUER=https://mittwald-oauth-server.fly.dev
COOKIES_SECURE=true
# DCR Initial Access Token (IAT) — DISABLED by default
# Note: Dynamic Client Registration in this server no longer requires an Initial Access Token.
# You may still set one for staging or lockdown scenarios, but it is not used in production by default.
# INITIAL_ACCESS_TOKEN=generate-secure-token-for-dcr

# node-oidc-provider JWT Configuration
# Persistent keystore path for signing keys (mounted volume in Fly)
JWKS_KEYSTORE_PATH=/app/jwks/jwks.json
TOKEN_TTL_ACCESS_TOKEN=3600
TOKEN_TTL_ID_TOKEN=3600
TOKEN_TTL_REFRESH_TOKEN=86400

# Mittwald Studio Integration (Static Client)
MITTWALD_OAUTH_BASE=https://api.mittwald.de
MITTWALD_OAUTH_AUTHORIZE_URL=https://api.mittwald.de/v2/oauth2/authorize
MITTWALD_OAUTH_TOKEN_URL=https://api.mittwald.de/v2/oauth2/token
MITTWALD_CLIENT_ID=mittwald-mcp-server

# Allowed Redirect URIs for DCR validation
#
# Recommended (production, open-but-safe): allow any https plus curated custom schemes
# covering common IDEs, CLIs, and desktop apps that support MCP + OAuth.
# ALLOWED_REDIRECT_URI_PATTERNS="https://*/*,claude://*,vscode://*,vscodium://*,cursor://*,windsurf://*,zed://*,jetbrains://*,lmstudio://*,postman://*,warp://*,amazonq://*"
#
# Optional add (specific ecosystems):
# - Sourcegraph Cody: sourcegraph://*
# - Memex desktop: memex://*
# - Theia / OpenSumi (if deep links used): theia://*,opensumi://*
# Append these to the list above only if you explicitly support them.
#
# Loopback redirects for native/CLI (Claude Desktop uses random localhost ports)
# ALLOWED_REDIRECT_URI_PATTERNS="https://*/*,http://localhost:*/*,http://127.0.0.1:*/*,http://[::1]:*/*,claude://*,vscode://*,vscodium://*,cursor://*,windsurf://*,zed://*,jetbrains://*,lmstudio://*,postman://*,warp://*,amazonq://*"
#
# Development-friendly defaults:
ALLOWED_REDIRECT_URI_PATTERNS=https://*/*,http://localhost:*/*,http://127.0.0.1:*/*,http://[::1]:*/*,claude://*,vscode://*,vscodium://*,cursor://*,windsurf://*,zed://*,jetbrains://*,lmstudio://*,postman://*,warp://*,amazonq://*

# Storage (Redis recommended for production)
REDIS_URL=redis://localhost:6379
STORAGE_ADAPTER=redis

# Server Configuration
PORT=3000
NODE_ENV=production
LOG_LEVEL=info
