# Mittwald OAuth Bridge – Environment Example
#
# Configure these variables for the standalone OAuth bridge service.

# ====================
# Core Runtime
# ====================

# REQUIRED: HTTP port exposed by the OAuth bridge.
PORT=3001

# REQUIRED: Public issuer claim embedded in bridge-issued JWTs.
BRIDGE_ISSUER=https://mittwald-oauth-server.fly.dev

# REQUIRED: Public base URL where the bridge is reachable.
BRIDGE_BASE_URL=https://mittwald-oauth-server.fly.dev


# ====================
# Mittwald OAuth Configuration
# ====================

# REQUIRED: Mittwald authorization endpoint for PKCE flows.
MITTWALD_AUTHORIZATION_URL=https://api.mittwald.de/oauth2/authorize

# REQUIRED: Mittwald token endpoint used during code exchange.
MITTWALD_TOKEN_URL=https://api.mittwald.de/oauth2/token

# REQUIRED: Mittwald client ID registered for the bridge (public PKCE client).
MITTWALD_CLIENT_ID=mittwald-mcp-bridge

# OPTIONAL: Comma-separated list of allowed redirect URIs for MCP clients.
BRIDGE_REDIRECT_URIS=https://chatgpt.com/connector_platform_oauth_redirect,https://claude.ai/api/mcp/auth_callback


# ====================
# JWT & Token Lifetimes
# ====================

# REQUIRED: Secret used to sign bridge-issued JWTs. Must match MCP `OAUTH_BRIDGE_JWT_SECRET`.
# Generate with: openssl rand -hex 32
BRIDGE_JWT_SECRET=REPLACE_WITH_GENERATED_SECRET_MINIMUM_64_HEX_CHARS

# OPTIONAL: Access token TTL returned to MCP clients (seconds).
BRIDGE_ACCESS_TOKEN_TTL_SECONDS=3600

# OPTIONAL: Refresh token TTL minted by the bridge (seconds).
BRIDGE_REFRESH_TOKEN_TTL_SECONDS=604800


# ====================
# Authorization State Storage
# ====================

# OPTIONAL: State store implementation (`memory` or `redis`). Use `redis` in production.
BRIDGE_STATE_STORE=redis

# REQUIRED when BRIDGE_STATE_STORE=redis: Redis connection string for bridge state.
BRIDGE_REDIS_URL=redis://localhost:6379

# OPTIONAL: TTL (seconds) for authorization state entries (default 600 = 10 minutes).
BRIDGE_STATE_TTL_SECONDS=600

# OPTIONAL: Prefix applied to Redis keys created by the bridge.
BRIDGE_STATE_PREFIX=mcp-oauth-bridge


# ====================
# Logging
# ====================

# OPTIONAL: Log level for the OAuth bridge (debug|info|warn|error).
LOG_LEVEL=info

