digraph ToolDependencies {
  rankdir=LR;
  node [shape=box, fontsize=10];
  edge [fontsize=8];

  subgraph cluster_access_users {
    label="access-users";
    style=filled;
    fillcolor="#e8eaf6";

    "ssh_user_update";
    "ssh_user_get";
    "sftp_user_delete";
    "sftp_user_create";
    "ssh_user_list";
  }

  subgraph cluster_project_foundation {
    label="project-foundation";
    style=filled;
    fillcolor="#e8f5e9";

    "server_list";
    "project_create";
    "server_get";
    "project_list";
  }

  subgraph cluster_organization {
    label="organization";
    style=filled;
    fillcolor="#fff3e0";

    "org_invite_list";
    "org_invite_revoke";
    "org_get";
    "org_delete";
    "org_membership_list";
    "org_invite_list_own";
    "org_list";
  }

  subgraph cluster_identity {
    label="identity";
    style=filled;
    fillcolor="#e3f2fd";

    "context_reset_session";
    "user_accessible_projects";
    "context_get";
  }

  subgraph cluster_apps {
    label="apps";
    style=filled;
    fillcolor="#fce4ec";

    "app_list";
    "app_dependency_list";
  }

  // Edges
  "ssh_user_update" -> "ssh_user_get" [label="100%", color="green", style="solid"];
  "server_list" -> "sftp_user_delete" [label="100%", color="green", style="solid"];
  "server_list" -> "project_create" [label="100%", color="green", style="solid"];
  "org_invite_list" -> "org_invite_revoke" [label="100%", color="green", style="solid"];
  "org_get" -> "org_delete" [label="100%", color="green", style="solid"];
  "sftp_user_create" -> "server_get" [label="100%", color="green", style="solid"];
  "context_reset_session" -> "org_membership_list" [label="100%", color="green", style="solid"];
  "ssh_user_get" -> "ssh_user_list" [label="50%", color="orange", style="solid"];
  "org_invite_list" -> "org_invite_list_own" [label="50%", color="orange", style="solid"];
  "user_accessible_projects" -> "org_invite_list" [label="50%", color="orange", style="solid"];
  "user_accessible_projects" -> "org_list" [label="50%", color="orange", style="solid"];
  "app_list" -> "app_dependency_list" [label="50%", color="orange", style="solid"];
  "org_membership_list" -> "project_list" [label="50%", color="orange", style="solid"];
  "context_get" -> "context_reset_session" [label="50%", color="orange", style="solid"];
  "user_accessible_projects" -> "context_get" [label="25%", color="red", style="solid"];
  "org_list" -> "context_get" [label="25%", color="red", style="solid"];
}