      }
    }
  ],
  "cleanupRequirements": [],
  "questionAnswers": [
    { "questionPattern": "source|staging", "answer": "The staging project" },
    { "questionPattern": "destination|production", "answer": "The production project" }
  ],
  "estimatedDuration": 5,
  "timeout": 15,
  "priority": "P1",
  "tags": ["apps", "migration", "planning", "mittwald"]
