{
  "id": "project-001-create-project",
  "title": "Create New Web Project",
  "description": "Customer wants to set up a new hosting environment for a web project.",
  "domain": "project-foundation",
  "prompt": "I'm starting a new web project and need to set up the hosting environment. I'll need a place to deploy my code with SSH access for deployments. Can you help me get this set up?",
  "expectedDomains": ["organization", "project-foundation", "access-users"],
  "expectedTools": [
    "org/list",
    "server/list",
    "project/create",
    "project/get",
    "ssh/user/create"
  ],
  "successCriteria": [
    {
      "description": "Project is created",
      "method": "log-pattern",
      "config": {
        "pattern": "project/create",
        "minOccurrences": 1
      }
    }
  ],
  "cleanupRequirements": [
    { "resourceType": "ssh-key", "identificationMethod": "log-parse", "deletionTool": "ssh/user/delete", "order": 1 },
    { "resourceType": "project", "identificationMethod": "log-parse", "deletionTool": "project/delete", "order": 2 }
  ],
  "questionAnswers": [
    { "questionPattern": "project name", "answer": "my-new-website" },
    { "questionPattern": "description", "answer": "A new website project" },
    { "questionPattern": "server", "answer": "Use the default server" }
  ],
  "estimatedDuration": 3,
  "timeout": 10,
  "priority": "P1",
  "tags": ["project", "setup", "ssh"]
}
