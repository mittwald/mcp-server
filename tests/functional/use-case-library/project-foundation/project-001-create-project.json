{
  "id": "project-001-create-project",
  "title": "List Projects and Servers on Mittwald",
  "description": "Check available projects and servers on Mittwald hosting.",
  "domain": "project-foundation",
  "prompt": "I'm starting a new web project and need to set up the hosting environment. I'll need a place to deploy my code with SSH access for deployments. Can you help me get this set up? Use the available Mittwald MCP tools to complete this - discover any needed information yourself and make reasonable choices for parameters I didn't specify. Do not ask me questions - just use the tools to get it done.",
  "expectedDomains": [
    "organization",
    "project-foundation",
    "access-users"
  ],
  "expectedTools": [
    "mcp__mittwald__mittwald_project_list",
    "mcp__mittwald__mittwald_server_list"
  ],
  "successCriteria": [
    {
      "description": "Project or server tools used",
      "method": "log-pattern",
      "config": {
        "pattern": "mcp__mittwald__mittwald_(project|server)",
        "minOccurrences": 1
      }
    }
  ],
  "cleanupRequirements": [
    {
      "resourceType": "ssh-key",
      "identificationMethod": "log-parse",
      "deletionTool": "ssh/user/delete",
      "order": 1
    },
    {
      "resourceType": "project",
      "identificationMethod": "log-parse",
      "deletionTool": "project/delete",
      "order": 2
    }
  ],
  "questionAnswers": [
    {
      "questionPattern": "project name",
      "answer": "my-new-website"
    },
    {
      "questionPattern": "description",
      "answer": "A new website project"
    },
    {
      "questionPattern": "server",
      "answer": "Use the default server"
    }
  ],
  "estimatedDuration": 2,
  "timeout": 10,
  "priority": "P1",
  "tags": [
    "project",
    "setup",
    "ssh"
  ]
}
