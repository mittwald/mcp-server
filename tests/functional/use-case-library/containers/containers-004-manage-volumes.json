{
  "id": "containers-004-manage-volumes",
  "title": "Create Persistent Storage Volumes",
  "description": "Developer needs to create and manage persistent volumes for containerized applications to store data that survives container restarts.",
  "domain": "containers",
  "prompt": "My Docker application needs persistent storage for uploaded files. Can you create a volume that will persist data even when the container is restarted? I need about 10GB of storage.",
