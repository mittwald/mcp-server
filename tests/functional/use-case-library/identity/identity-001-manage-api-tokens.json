{
  "id": "identity-001-manage-api-tokens",
  "title": "Manage API Tokens for CI/CD Integration",
  "description": "Developer wants to create an API token for their CI/CD pipeline to automate deployments on Mittwald.",
  "domain": "identity",
  "prompt": "I need to set up automated deployments from our GitLab CI pipeline to my Mittwald hosting. Use the Mittwald MCP tools to first show me what API tokens I already have, then create a new one called 'gitlab-deploy' with both read and write permissions.",
  "expectedDomains": ["identity"],
  "expectedTools": [
    "mcp__mittwald__mittwald_user_api_token_list",
    "mcp__mittwald__mittwald_user_api_token_create"
  ],
  "successCriteria": [
    {
      "description": "API token list tool invoked",
      "method": "log-pattern",
      "config": {
        "pattern": "mcp__mittwald__mittwald_user_api_token_list",
        "minOccurrences": 1
      }
    },
    {
      "description": "API token operations succeeded",
      "method": "mcp-outcome",
      "config": {
        "toolName": "mcp__mittwald__mittwald_user_api_token",
        "successPattern": "(tokenId|apiTokenId|created|token|expires)",
        "failurePattern": "(403|Permission\\s*Denied|access\\s*denied|error)"
      }
    }
  ],
  "cleanupRequirements": [],
  "questionAnswers": [
    { "questionPattern": "description|purpose", "answer": "GitLab CI/CD deployment automation" },
    { "questionPattern": "expir|duration", "answer": "1 year" },
    { "questionPattern": "permission|scope|role", "answer": "api_read and api_write" }
  ],
  "estimatedDuration": 3,
  "timeout": 10,
  "priority": "P2",
  "tags": ["identity", "api-token", "ci-cd", "automation", "mittwald"]
}
